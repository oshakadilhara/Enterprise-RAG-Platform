# Application
APP_NAME=Enterprise RAG Platform
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://rag_user:rag_password@localhost:5432/rag_platform
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-jwt-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=rag_

# OpenSearch
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=Admin123!
OPENSEARCH_INDEX_PREFIX=rag_

# S3 / Object Storage
S3_BUCKET=rag-documents
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# Embedding Provider: openai | gemini | bge | sentence_transformers
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# LLM Provider: openai | gemini | claude | ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
# Cheap model for internal calls like query expansion (Cost Tier 1)
LLM_UTILITY_MODEL=gpt-4o-mini
# Cap on answer output tokens (output is 4x input cost)
ANSWER_MAX_TOKENS=1024
# Chat history token budget per request
HISTORY_MAX_TOKENS=800

# API Keys
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Reranker: bge | cross_encoder
RERANKER_PROVIDER=bge
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Hybrid Search Weights
VECTOR_SEARCH_WEIGHT=0.6
BM25_SEARCH_WEIGHT=0.4
HYBRID_TOP_K=50
RERANK_TOP_K=5

# Retrieval Confidence / Explainable AI
# Skip LLM query expansion when top cosine similarity >= this value
EXPANSION_CONFIDENCE_THRESHOLD=0.7
# Withhold the answer when the best rerank score is below this value
RETRIEVAL_CONFIDENCE_THRESHOLD=0.3
ABSTAIN_ON_LOW_CONFIDENCE=true

# Caching (Cost Optimization)
ENABLE_EMBEDDING_CACHE=true
EMBEDDING_CACHE_TTL_SECONDS=86400
ENABLE_SEMANTIC_CACHE=true
SEMANTIC_CACHE_TTL_SECONDS=3600

# Chunking
CHUNKING_STRATEGY=recursive
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Rate Limiting & Tenant Budgets
RATE_LIMIT_PER_MINUTE=60
USER_RATE_LIMIT_PER_MINUTE=30
ORG_RATE_LIMIT_PER_MINUTE=500
ORG_DAILY_TOKEN_BUDGET=2000000

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_ENABLED=true

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
